[
  {
    "context": "Editor",
    "unbind": {
      "ctrl-y": "editor::Redo",
      "ctrl-;": "editor::ToggleLineNumbers",
      "ctrl-'": "editor::ToggleSelectedDiffHunks",
    },
    "bindings": {
      "ctrl-;": "editor::ToggleSelectedDiffHunks",
      "ctrl-y": [
        "action::Sequence",
        [
          [
            "editor::MoveToBeginningOfLine",
            { "stop_at_indent": true, "stop_at_soft_wraps": false },
          ],
          ["editor::SelectToEndOfLine", { "stop_at_soft_wraps": false }],
          "editor::Paste",
        ],
      ],
    },
  },

  {
    "context": "Pane",
    "unbind": {
      "ctrl-shift-f": "project_search::ToggleFocus",
    },
    "bindings": {
      "ctrl-shift-f": "workspace::NewSearch",
    },
  },

  {
    "context": "ProjectSearchBar",
    "unbind": {
      "ctrl-shift-f": "search::FocusSearch",
    },
  },

  {
    "context": "Workspace",
    "unbind": {
      "ctrl-`": "terminal_panel::Toggle",
    },
    "bindings": {
      "ctrl-'": "terminal_panel::Toggle",
      "ctrl-#": "workspace::NewCenterTerminal",
    },
  },
]
